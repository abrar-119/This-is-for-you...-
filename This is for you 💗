<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Happy Birthday My Love</title>
    
    <!-- Premium Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;600&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

    <style>
        *, *::before, *::after { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        :root {
            --bg-dark: #0a0a0a;
            --bg-card: rgba(20, 20, 20, 0.8);
            --gold-primary: #dfba6b;
            --gold-gradient: linear-gradient(135deg, #bf953f 0%, #fcf6ba 25%, #b38728 50%, #fbf5b7 75%, #aa771c 100%);
            --text-light: #f5f5f5;
            --text-muted: #b5b5b5;
            --font-serif: 'Playfair Display', serif;
            --font-sans: 'Montserrat', sans-serif;
            --border-gold: rgba(191, 149, 63, 0.3);
        }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: var(--bg-dark); font-family: var(--font-sans);
            color: var(--text-light); scroll-behavior: smooth; overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
        }
        body.locked { overflow: hidden; position: fixed; width: 100%; height: 100%; }
        .hidden { display: none !important; }

        /* iPhone Safe Area Fixes & Dynamic Height */
        #loader, #gift-screen {
            position: fixed; top: 0; left: 0; width: 100%; 
            height: 100vh; height: 100dvh; /* Dynamic view height for iOS Safari */
            background-color: #050505; z-index: 9999; display: flex; justify-content: center; align-items: center;
        }
        #gift-screen { z-index: 998; background: radial-gradient(circle at center, #1a1a1a 0%, #050505 100%); }

        /* LOADING BAR */
        .loader-content { text-align: center; width: 85%; max-width: 400px; padding: 20px; }
        #loader-text {
            font-family: var(--font-serif); font-size: 1.3rem; margin-bottom: 20px;
            background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 2px;
        }
        .progress-bar-container { width: 100%; height: 3px; background: rgba(255, 255, 255, 0.05); border-radius: 10px; overflow: hidden; }
        .progress-bar { width: 0%; height: 100%; background: var(--gold-gradient); transition: width 0.1s linear; }

        /* FLOATING MUSIC CONTROLLER */
        #audio-control { position: fixed; top: max(20px, env(safe-area-inset-top)); right: 20px; z-index: 999; }
        #music-toggle {
            background: rgba(15, 15, 15, 0.8); border: 1px solid var(--border-gold);
            border-radius: 50%; width: 45px; height: 45px; color: var(--gold-primary);
            cursor: pointer; backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
            display: flex; justify-content: center; align-items: center; font-size: 1.1rem;
        }
        .animated-icon { animation: rotateMusic 4s linear infinite; }
        @keyframes rotateMusic { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

        /* INTERACTIVE LUXURY BOX */
        .gift-wrapper { text-align: center; padding: 20px; width: 100%; }
        .gift-instruction { font-family: var(--font-serif); font-style: italic; color: var(--text-muted); font-size: 1.1rem; margin-bottom: 40px; animation: pulse 2s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 0.5; } 50% { opacity: 1; } }
        
        .luxury-box { position: relative; width: 140px; height: 140px; margin: 0 auto; cursor: pointer; animation: floatBox 3s infinite ease-in-out; }
        @keyframes floatBox { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }
        .box-body { position: absolute; bottom: 0; width: 100%; height: 105px; background: #151515; border: 2px solid #bf953f; border-radius: 4px; }
        .box-lid { position: absolute; top: 22px; left: -5px; width: 150px; height: 25px; background: #222; border: 2px solid #fcf6ba; border-radius: 3px; z-index: 10; }
        .box-ribbon-vertical { position: absolute; top: 22px; left: 60px; width: 20px; height: 118px; background: var(--gold-gradient); z-index: 5; }
        .box-ribbon-horizontal { position: absolute; top: 65px; left: 0; width: 140px; height: 20px; background: var(--gold-gradient); z-index: 5; }
        .box-glow { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle, rgba(223,186,107,0.3) 0%, transparent 70%); transform: scale(2); z-index: -1; }

        /* MAIN CONTENT AREA */
        .hero-section {
            position: relative; height: 100vh; height: 100dvh; width: 100%; display: flex; justify-content: center; align-items: center; text-align: center;
            background: url('https://images.unsplash.com/photo-1507504038482-7621cae8c6f9?q=80&w=1920') center/cover no-repeat;
        }
        .overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(10,10,10,0.85), var(--bg-dark)); }
        .hero-inner { position: relative; z-index: 2; padding: 20px; }
        .hero-subtitle { font-family: var(--font-serif); font-size: 1.1rem; letter-spacing: 3px; color: var(--gold-primary); text-transform: uppercase; }
        .hero-title { font-family: var(--font-serif); font-size: 2.5rem; font-weight: 700; margin: 15px 0; background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1.3; }
        
        .scroll-indicator { position: absolute; bottom: calc(20px + env(safe-area-inset-bottom)); left: 50%; transform: translateX(-50%); font-size: 0.8rem; color: var(--text-muted); letter-spacing: 2px; text-transform: uppercase; display: flex; flex-direction: column; align-items: center;}
        .scroll-indicator i { margin-top: 10px; color: var(--gold-primary); animation: bounce 2s infinite; }
        @keyframes bounce { 0%, 20%, 50%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-6px); } }

        /* GLASSMORPHISM CARDS (iOS Optimized Blur) */
        .glass-card { 
            background: var(--bg-card); 
            backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); 
            border: 1px solid var(--border-gold); border-radius: 16px; 
            padding: 30px 20px; box-shadow: 0 15px 35px rgba(0, 0, 0, 0.5); 
        }
        .letter-section { padding: 60px 15px; max-width: 600px; margin: 0 auto; }
        .card-header { text-align: center; margin-bottom: 20px; }
        .gold-heart { color: #dfba6b; font-size: 1.6rem; animation: heartBeat 1.5s infinite; }
        @keyframes heartBeat { 0%, 40%, 100% { transform: scale(1); } 20%, 60% { transform: scale(1.15); } }
        .card-header h2 { font-family: var(--font-serif); font-size: 1.6rem; margin: 10px 0 0 0; }
        .letter-body { font-size: 1rem; line-height: 1.8; color: #eaeaea; white-space: pre-wrap; font-weight: 300; text-align: left; }

        /* GALLERY (Swiper Touch Control Smoothness) */
        .gallery-section { padding: 60px 10px; text-align: center; }
        .section-title { font-family: var(--font-serif); font-size: 1.8rem; background: var(--gold-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin: 0 0 5px 0; }
        .section-subtitle { font-size: 0.9rem; color: var(--text-muted); font-style: italic; margin-bottom: 30px; padding: 0 10px; }
        
        .mySwiper { width: 100%; max-width: 100%; padding-bottom: 30px; overflow: visible !important; }
        .swiper-slide { width: 260px; height: 350px; border-radius: 12px; border: 1px solid var(--border-gold); overflow: hidden; background: #151515; transform: translate3d(0,0,0); }
        .slide-img-container { width: 100%; height: 100%; position: relative; }
        .slide-img-container img { width: 100%; height: 100%; object-fit: cover; }
        .photo-fallback { position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; text-align: center; color: var(--text-muted); }
        .photo-fallback i { font-size: 2.2rem; color: var(--gold-primary); margin-bottom: 12px; }

        /* VIDEO */
        .video-section { padding: 40px 15px; max-width: 700px; margin: 0 auto; }
        .video-wrapper { width: 100%; border-radius: 12px; overflow: hidden; border: 1px solid rgba(191,149,63,0.2); background: #000; }
        video { width: 100%; display: block; object-fit: contain; }

        /* WISHES & BLESSINGS */
        .blessings-section { padding: 60px 15px; max-width: 850px; margin: 0 auto; text-align: center; }
        .blessings-grid { display: flex; flex-direction: column; gap: 15px; margin-top: 25px; align-items: center; }
        .blessing-card { width: 100%; max-width: 450px; text-align: left; padding: 20px; }
        .blessing-icon { font-size: 2rem; margin-bottom: 8px; }
        .blessing-card h3 { font-family: var(--font-serif); color: var(--gold-primary); margin: 0 0 6px 0; font-size: 1.2rem; }
        .blessing-card p { margin: 0; font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; }

        footer { text-align: center; padding: 40px 20px calc(40px + env(safe-area-inset-bottom)) 20px; background: #050505; border-top: 1px solid rgba(191,149,63,0.1); }
        .footer-text { font-family: var(--font-serif); font-size: 1.1rem; margin: 0; }
        .footer-text span { color: var(--gold-primary); }
        .copyright { font-size: 0.75rem; color: rgba(255,255,255,0.25); margin-top: 8px; }

        /* Responsive scaling for bigger displays like iPhone 17 Pro Max */
        @media (min-width: 440px) {
            .hero-title { font-size: 3rem; }
            .section-title { font-size: 2.2rem; }
            .swiper-slide { width: 290px; height: 390px; }
            .blessings-grid { flex-direction: row; flex-wrap: wrap; justify-content: center; }
            .blessing-card { width: calc(50% - 10px); }
        }
    </style>
</head>
<body class="locked">

    <!-- 1. LUXURY LOADER -->
    <div id="loader">
        <div class="loader-content">
            <h1 id="loader-text">Preparing Your Luxury Surprise...</h1>
            <div class="progress-bar-container">
                <div class="progress-bar"></div>
            </div>
        </div>
    </div>

    <!-- AUDIO ELEMENT (iOS Optimized) -->
    <audio id="bg-music" loop playsinline>
        <source src="music/background.mp3" type="audio/mpeg">
    </audio>

    <!-- FLOATING MUSIC BUTTON -->
    <div id="audio-control" class="hidden">
        <button id="music-toggle" aria-label="Toggle Music">
            <i class="fas fa-music animated-icon"></i>
        </button>
    </div>

    <!-- 2. INTRO GIFT BOX SCREEN -->
    <div id="gift-screen" class="hidden">
        <div class="gift-wrapper">
            <h2 class="gift-instruction">Tap on the premium box to unbox your surprise... 🎁</h2>
            <div class="luxury-box" id="interactive-box">
                <div class="box-lid"></div>
                <div class="box-ribbon-vertical"></div>
                <div class="box-ribbon-horizontal"></div>
                <div class="box-body"></div>
                <div class="box-glow"></div>
            </div>
        </div>
    </div>

    <!-- 3. MAIN SURPRISE CONTENT -->
    <div id="main-content" class="hidden">
        
        <!-- HERO SECTION -->
        <section class="hero-section">
            <div class="overlay"></div>
            <div class="hero-inner">
                <p class="hero-subtitle" id="hero-sub">To My Wonderful Husband</p>
                <h1 class="hero-title" id="welcome-msg">Happy Birthday</h1>
                <div class="scroll-indicator">
                    <span>Scroll Down for Memories</span>
                    <i class="fas fa-chevron-down"></i>
                </div>
            </div>
        </section>

        <!-- LOVE LETTER CARD -->
        <section class="letter-section">
            <div class="glass-card letter-card">
                <div class="card-header">
                    <i class="fas fa-heart gold-heart"></i>
                    <h2>A Letter From My Heart</h2>
                </div>
                <div class="letter-body" id="typed-letter"></div>
            </div>
        </section>

        <!-- SWIPER MEMORIES GALLERY -->
        <section class="gallery-section">
            <h2 class="section-title">Our Beautiful Memories</h2>
            <p class="section-subtitle">Every moment spent with you is a true treasure</p>
            
            <div class="swiper mySwiper">
                <div class="swiper-wrapper" id="gallery-wrapper"></div>
                <div class="swiper-pagination"></div>
            </div>
        </section>

        <!-- SURPRISE VIDEO SECTION -->
        <section class="video-section" id="video-container">
            <div class="glass-card video-card">
                <h2 class="section-title" style="margin-bottom: 20px;">A Special Message</h2>
                <div class="video-wrapper">
                    <video id="surprise-video" controls playsinline poster="https://images.unsplash.com/photo-1516450360452-9312f5e86fc7?q=80&w=1200">
                        <source src="" id="video-source" type="video/mp4">
                    </video>
                </div>
            </div>
        </section>

        <!-- PRAYERS & BLESSINGS -->
        <section class="blessings-section">
            <h2 class="section-title">My Prayers & Wishes For You</h2>
            <div class="blessings-grid" id="blessings-grid"></div>
        </section>

        <!-- FOOTER -->
        <footer>
            <p class="footer-text">Created with ❤️ by <span id="wifey-name">Your Wife</span></p>
            <p class="copyright">Forever & Always | © 2026</p>
        </footer>

    </div>

    <!-- Core CDNs -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        // ==========================================
        // 🛠️ CONFIG DATA (NAME & WORDS)
        // ==========================================
        const CONFIG = {
            husbandName: "Rahul", 
            wifeName: "Anjali",   
            loadingText: "Preparing Your Luxury Surprise...",
            welcomeMessage: "Happy Birthday to My King, My Forever Love! ❤️",
            
            letterText: `Dearest Husband,\n\nOn this beautiful day, I want to take a moment to celebrate the most amazing man in my life. You are not just my husband; you are my best friend, my safest haven, and my greatest blessing.\n\nThank you for every smile, every warm hug, and for making our life feel like a beautiful dream. Your kindness, strength, and love inspire me every single day.\n\nAs you step into another wonderful year, I wish you endless laughter, unmatched success, and all the happiness in the universe. I promise to stand by you, hold your hand, and love you more with every passing heartbeat.\n\nHappy Birthday, My Love! 🥂✨\n\nForever Yours,\nYour Loving Wife`,

            photos: [
                "photos/photo1.jpg",
                "photos/photo2.jpg",
                "photos/photo3.jpg",
                "photos/photo4.jpg",
                "photos/photo5.jpg"
            ],
            videoUrl: "video/birthday_video.mp4", 
            showVideo: true, 

            blessings: [
                { icon: "✨", title: "Endless Success", text: "May your career and passions soar to the highest peaks." },
                { icon: "❤️", title: "Boundless Love", text: "May our beautiful bond grow deeper and stronger with every single breath." },
                { icon: "🥂", title: "Good Health & Joy", text: "Wishing you a lifetime of vibrant health, energy, and pure laughter." },
                { icon: "🌟", title: "Brightest Future", text: "May every single dream you hold in your heart turn into beautiful reality." }
            ]
        };

        // ==========================================
        // 📱 COMPATIBILITY RUNTIME LOGIC
        // ==========================================
        document.addEventListener("DOMContentLoaded", () => {
            let progress = 0;
            const progressBar = document.querySelector(".progress-bar");
            document.getElementById("loader-text").textContent = CONFIG.loadingText;

            const loaderInterval = setInterval(() => {
                progress += 5;
                if (progressBar) progressBar.style.width = `${progress}%`;
                if (progress >= 100) {
                    clearInterval(loaderInterval);
                    gsap.to("#loader", { opacity: 0, duration: 0.5, onComplete: () => {
                        document.getElementById("loader").classList.add("hidden");
                        document.getElementById("gift-screen").classList.remove("hidden");
                    }});
                }
            }, 50);

            // iPhone-Safe Audio & Unboxing Trigger
            document.getElementById("interactive-box").addEventListener("click", () => {
                triggerConfettiExplosion();
                
                // iOS Audio Activation Policy Safe-Pass
                const bgMusic = document.getElementById("bg-music");
                bgMusic.play().catch(err => console.log("Audio play deferred or muted:", err));

                gsap.to(".box-lid", { y: -70, opacity: 0, rotation: 10, duration: 0.5 });
                gsap.to(".box-body, .box-ribbon-vertical, .box-ribbon-horizontal", { 
                    scaleY: 0, opacity: 0, duration: 0.4, delay: 0.1, onComplete: revealMainSurprise 
                });
            });

            function revealMainSurprise() {
                document.body.classList.remove("locked");
                document.getElementById("gift-screen").classList.add("hidden");
                document.getElementById("main-content").classList.remove("hidden");
                document.getElementById("audio-control").classList.remove("hidden");

                // Inject Config Data Safely
                document.getElementById("welcome-msg").textContent = CONFIG.welcomeMessage;
                document.getElementById("wifey-name").textContent = CONFIG.wifeName;
                document.getElementById("hero-sub").textContent = `To My Wonderful Husband, ${CONFIG.husbandName}`;

                setupGallery();
                setupVideo();
                setupBlessings();
                startLetterTypingAnimation();
            }

            // Audio Toggle Controller
            const bgMusic = document.getElementById("bg-music");
            const musicToggle = document.getElementById("music-toggle");
            musicToggle.addEventListener("click", () => {
                if (bgMusic.paused) {
                    bgMusic.play();
                    musicToggle.querySelector("i").classList.add("animated-icon");
                } else {
                    bgMusic.pause();
                    musicToggle.querySelector("i").classList.remove("animated-icon");
                }
            });

            function setupGallery() {
                const wrapper = document.getElementById("gallery-wrapper");
                CONFIG.photos.forEach((photoUrl, idx) => {
                    const slide = document.createElement("div");
                    slide.class
